{
  "name": "core-loop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "npm run dev --workspace @core-loop/threshold-lab --",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "build": "npm run build --workspace @core-loop/threshold-lab",
    "content:validate": "vitest run packages/content/tests/content.test.ts",
    "saves:validate": "vitest run packages/core/tests/hardening.test.ts -t \"versioned save migrations\"",
    "replay:verify": "vitest run packages/core/tests/hardening.test.ts -t \"deterministic replay\"",
    "simulate": "vite-node tools/simulate.ts",
    "simulate:smoke": "vitest run packages/simulation/tests/simulation.test.ts -t \"CI smoke\"",
    "build:all": "npm run build --workspaces --if-present",
    "check:no-binaries": "node tools/check-no-binaries.mjs",
    "docs:check": "node tools/check-doc-links.mjs",
    "create-game": "node tools/create-game.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^22.20.1",
    "eslint": "^9.32.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.0.6",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.4"
  }
}
